// Custom behaviors for Sofle Eyelash
// - Long-press helper (tap = key1, hold = key2)

#include <dt-bindings/zmk/keys.h>

 / {
     behaviors {
         /* Generic long-press (hold-tap) behavior.
          * Use as:  &lp <HOLD_key> <TAP_key>
          * Example: &lp ESC GRAVE  => tap ` , hold = Esc
          */
         lp: long_press_to_key {
             compatible = "zmk,behavior-hold-tap";
             label = "LP";
             #binding-cells = <2>;
             flavor = "tap-preferred";
             tapping-term-ms = <200>;
             quick-tap-ms = <175>;
             bindings = <&kp>, <&kp>;
         };

         /* Optional: global tweaks for built-in mod-tap (&mt) */
         &mt {
             flavor = "balanced";
             quick-tap-ms = <150>;
         };
     };
 };
