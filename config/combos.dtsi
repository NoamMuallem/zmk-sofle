// Two-keys-at-once (combos) for Sofle Eyelash

#include <dt-bindings/zmk/keys.h>

/ {
    combos {
        compatible = "zmk,combos";
        combo-term-ms = <35>;

        /* TAB + GRAVE → ESC  (on base layer)
         * key-positions use matrix order (left-to-right, top-to-bottom)
         * Adjust numbers if needed after testing.
         */
        esc_from_tab_grave {
            key-positions = <6 0>;
            bindings = <&kp ESC>;
            layers = <0>;
            timeout-ms = <35>;
        };
    };
};
