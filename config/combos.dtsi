// Two-keys-at-once (combos)
#include <dt-bindings/zmk/keys.h>

/ {
    combos {
        compatible = "zmk,combos";
        combo-term-ms = <35>;

        /* TAB + GRAVE -> ESC  (base layer)
         * IMPORTANT: positions are matrix positions (NOT keycodes).
         * Replace <TAB_POS GRAVE_POS> with your actual numbers (see Step 3).
         */
        esc_from_tab_grave {
            key-positions = <6 0>;
            bindings = <&kp ESC>;
            layers = <0>;
            timeout-ms = <35>;
        };
    };
};
